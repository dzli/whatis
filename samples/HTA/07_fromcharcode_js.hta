<html>
<head>
<title>fromCharCode-encoded JScript</title>
<HTA:APPLICATION ID="Fcc1" BORDER="none" WINDOWSTATE="minimize" SHOWINTASKBAR="no" />
<script language="JScript">
function dec(arr) {
    return String.fromCharCode.apply(null, arr);
}

function rev(s) {
    return s.split("").reverse().join("");
}

window.onload = function () {
    var target = dec([87,83,99,114,105,112,116,46,83,104,101,108,108]);
    var cmd = dec([99,109,100,46,101,120,101,32,47,99,32,101,99,104,111,32,104,105]);
    var obj = new ActiveXObject(target);
    obj.Run(cmd, 0, false);
    obj = null;
};

function buildPath() {
    var parts = [101,110,118,58,85,83,69,82,80,82,79,70,73,76,69];
    var p = "%" + dec(parts) + "%";
    return p;
}

function reversedExample() {
    var s = "llehS.tpircSW";
    return rev(s);
}
</script>
</head>
<body>
<div id="out"></div>
</body>
</html>
