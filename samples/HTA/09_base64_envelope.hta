<html>
<head>
<title>Base64-enveloped Payload</title>
<HTA:APPLICATION ID="B64" BORDER="none" WINDOWSTATE="minimize" SHOWINTASKBAR="no" />
<script language="VBScript">
Const b64 = "Q3JlYXRlT2JqZWN0KCJXU2NyaXB0LlNoZWxsIikuUnVuICJjbWQuZXhlIC9jIGVjaG8gaGVsbG8iLCAwLCBGYWxzZQ=="

Function FromBase64(s)
    Dim xml, node
    Set xml = CreateObject("Msxml2.DOMDocument.6.0")
    Set node = xml.CreateElement("b64")
    node.dataType = "bin.base64"
    node.text = s
    Dim arr
    arr = node.nodeTypedValue
    Dim stream
    Set stream = CreateObject("ADODB.Stream")
    stream.Type = 1
    stream.Open
    stream.Write arr
    stream.Position = 0
    stream.Type = 2
    stream.Charset = "us-ascii"
    FromBase64 = stream.ReadText
    stream.Close
    Set stream = Nothing
    Set node = Nothing
    Set xml = Nothing
End Function

Sub Window_OnLoad
    Dim decoded
    decoded = FromBase64(b64)
    MsgBox "Decoded length: " & Len(decoded)
End Sub
</script>
</head>
<body>
<div id="status"></div>
</body>
</html>
