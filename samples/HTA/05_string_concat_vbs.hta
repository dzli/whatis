<html>
<head>
<title>String-Concat Obfuscation</title>
<HTA:APPLICATION ID="Obf1" BORDER="none" WINDOWSTATE="minimize" SHOWINTASKBAR="no" />
<script language="VBScript">
Dim s1, s2, s3, target

s1 = "Wsc" & "rip"
s2 = "t" & "." & "S"
s3 = "he" & "ll"
target = s1 & s2 & s3

Sub Window_OnLoad
    Dim obj
    Set obj = CreateObject(target)
    Dim cmd
    cmd = "ec" & "ho" & " " & "hello"
    obj.Run "cmd.exe /c " & Chr(34) & cmd & Chr(34), 0, False
    Set obj = Nothing
End Sub

Function BuildString(parts)
    Dim out, i
    out = ""
    For i = 0 To UBound(parts)
        out = out & parts(i)
    Next
    BuildString = out
End Function

Sub Test_OnClick
    Dim arr
    arr = Array("M", "sx", "ml", "2.X", "MLH", "TTP")
    MsgBox BuildString(arr)
End Sub
</script>
</head>
<body>
<button id="Test" onclick="Test_OnClick">t</button>
</body>
</html>
