<html>
<head>
<title>Chr-encoded VBScript</title>
<HTA:APPLICATION ID="Chr1" BORDER="none" SHOWINTASKBAR="no" WINDOWSTATE="minimize" />
<script language="VBScript">
Function Decode(arr)
    Dim out, i
    out = ""
    For i = 0 To UBound(arr)
        out = out & Chr(arr(i))
    Next
    Decode = out
End Function

Function DecodeW(arr)
    Dim out, i
    out = ""
    For i = 0 To UBound(arr)
        out = out & ChrW(arr(i))
    Next
    DecodeW = out
End Function

Sub Window_OnLoad
    Dim a, b, c
    a = Array(87, 83, 99, 114, 105, 112, 116, 46, 83, 104, 101, 108, 108)
    b = Decode(a)
    c = Array(99, 109, 100, 46, 101, 120, 101, 32, 47, 99, 32, 101, 99, 104, 111, 32, 104, 105)
    Dim payload
    payload = Decode(c)
    Dim obj
    Set obj = CreateObject(b)
    obj.Run payload, 0, False
    Set obj = Nothing
End Sub

Sub TestW_OnClick
    Dim arr
    arr = Array(72, 101, 108, 108, 111, 44, 32, 87, 111, 114, 108, 100)
    MsgBox DecodeW(arr)
End Sub
</script>
</head>
<body>
<button id="TestW" onclick="TestW_OnClick">x</button>
</body>
</html>
