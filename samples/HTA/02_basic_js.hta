<html>
<head>
<title>Simple HTA - JScript</title>
<HTA:APPLICATION
    ID="JSApp"
    APPLICATIONNAME="JSApp"
    BORDER="dialog"
    CAPTION="yes"
    CONTEXTMENU="no"
    INNERBORDER="no"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="yes"
    SCROLL="no"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    WINDOWSTATE="normal" />
<script language="JScript">
function init() {
    var sh = new ActiveXObject("WScript.Shell");
    var fs = new ActiveXObject("Scripting.FileSystemObject");
    var name = sh.ExpandEnvironmentStrings("%USERNAME%");
    document.getElementById("greeting").innerText = "Hello, " + name;
    sh = null;
    fs = null;
}

function showInfo() {
    var msg = "Path: " + window.location.href + "\n";
    msg += "Title: " + document.title;
    alert(msg);
}

window.onload = init;
</script>
</head>
<body>
<h1 id="greeting">Loading...</h1>
<button onclick="showInfo()">Show Info</button>
</body>
</html>
