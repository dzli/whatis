<html>
<head>
<title>Heavy HTA Window Config</title>
<HTA:APPLICATION
    ID="FullConfig"
    APPLICATIONNAME="FullConfig"
    BORDER="thick"
    BORDERSTYLE="raised"
    CAPTION="yes"
    COMMANDLINE="--option=value"
    CONTEXTMENU="yes"
    ICON="app.ico"
    INNERBORDER="yes"
    MAXIMIZEBUTTON="yes"
    MINIMIZEBUTTON="yes"
    NAVIGABLE="no"
    SCROLL="yes"
    SCROLLFLAT="no"
    SELECTION="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    VERSION="1.0.0"
    WINDOWSTATE="maximize" />
<script language="VBScript">
Sub Window_OnLoad
    Window.ResizeTo 800, 600
    Window.MoveTo 100, 100
End Sub

Sub ShowSettings_OnClick
    Dim msg
    msg = "Application: " & SimpleApp.applicationName & vbCrLf
    msg = msg & "Version: " & SimpleApp.version & vbCrLf
    msg = msg & "CommandLine: " & SimpleApp.commandLine & vbCrLf
    MsgBox msg, vbInformation, "Settings"
End Sub
</script>
</head>
<body style="font-family: Segoe UI; background: #f5f5f5;">
<h1>Configuration Sample</h1>
<button id="ShowSettings" onclick="ShowSettings_OnClick">Show</button>
</body>
</html>
