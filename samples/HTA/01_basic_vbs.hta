<html>
<head>
<title>Simple HTA - VBScript</title>
<HTA:APPLICATION
    ID="SimpleApp"
    APPLICATIONNAME="SimpleApp"
    BORDER="thin"
    CAPTION="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    WINDOWSTATE="normal" />
<script language="VBScript">
Sub Window_OnLoad
    Dim shell
    Set shell = CreateObject("WScript.Shell")
    MsgBox "Hello from HTA at " & Now()
    Set shell = Nothing
End Sub

Sub btnClose_OnClick
    Window.Close()
End Sub
</script>
</head>
<body>
<h1>Sample HTA</h1>
<p>This is a minimal HTML Application.</p>
<button id="btnClose" onclick="btnClose_OnClick">Close</button>
</body>
</html>
