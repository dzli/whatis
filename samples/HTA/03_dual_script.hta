<html>
<head>
<title>HTA with Both Script Engines</title>
<HTA:APPLICATION
    ID="DualApp"
    APPLICATIONNAME="DualApp"
    BORDER="thick"
    CAPTION="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    WINDOWSTATE="normal"
    NAVIGABLE="no"
    SELECTION="no"
    SCROLL="auto" />

<script language="VBScript">
Function VBSGetTime()
    VBSGetTime = FormatDateTime(Now, vbLongTime)
End Function

Function VBSGetUser()
    Dim sh
    Set sh = CreateObject("WScript.Shell")
    VBSGetUser = sh.ExpandEnvironmentStrings("%USERNAME%")
    Set sh = Nothing
End Function

Sub Window_OnLoad
    Dim user
    user = VBSGetUser()
    JsRender(user)
End Sub
</script>

<script language="JScript">
function JsRender(user) {
    var div = document.getElementById("output");
    div.innerText = "Welcome " + user + " (" + VBSGetTime() + ")";
}

function JsResize() {
    window.resizeTo(640, 480);
}
</script>
</head>
<body onload="VBSGetTime();">
<div id="output"></div>
<button onclick="JsResize()">Resize</button>
</body>
</html>
